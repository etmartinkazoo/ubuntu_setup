---
// The signature: a faithful monochrome terminal. The only saturated
// colour on the page is the caret and the prompt symbol.
interface Props {
  label?: string;
  class?: string;
}
const { label = 'you@ubuntu: ~/ubuntu_setup', class: cls = '' } = Astro.props;
---

<div class:list={['group border border-ink bg-ink text-[#e9e7e2] shadow-[0_1px_0_0_#d5d2cb]', cls]}>
  <!-- title bar -->
  <div class="flex items-center gap-2 border-b border-white/10 px-4 py-2.5">
    <span class="h-2.5 w-2.5 border border-white/25"></span>
    <span class="h-2.5 w-2.5 border border-white/25"></span>
    <span class="h-2.5 w-2.5 border border-white/25"></span>
    <span class="ml-3 truncate font-mono text-[11px] tracking-wide text-white/40">{label}</span>
  </div>

  <!-- body -->
  <div class="px-5 py-5 font-mono text-[13px] leading-[1.75]">
    <div id="term-line" class="whitespace-pre-wrap break-all">
      <span class="text-ubuntu select-none">$ </span><span id="term-typed"></span><span
        class="caret"
        id="term-caret"></span>
    </div>
    <div id="term-output" class="mt-3 space-y-1 text-white/55" hidden></div>
  </div>
</div>

<script>
  const COMMAND = 'git clone https://github.com/etmartinkazoo/ubuntu_setup.git && cd ubuntu_setup && ./setup/bootstrap.sh';
  // These are the actual stage lines bootstrap.sh prints (one per step).
  const OUTPUT = [
    '→ preflight',
    '→ apt packages',
    '→ herdr',
    '→ mise runtimes',
    '→ dotfiles',
    '→ privacy — silencing calls home',
    '→ encrypted DNS',
    '→ hardening',
    '→ power & efficiency',
    '→ firefox — defaults, uBlock, blocklist',
    '✓ done — restart your shell:  exec bash',
  ];

  const typed = document.getElementById('term-typed');
  const caret = document.getElementById('term-caret');
  const output = document.getElementById('term-output');
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  function renderOutput() {
    if (!output) return;
    output.hidden = false;
    output.innerHTML = OUTPUT.map(
      (l) => `<div>${l.replace('✓', '<span class="text-ubuntu">✓</span>')}</div>`,
    ).join('');
  }

  if (!typed) {
    /* no-op */
  } else if (reduce) {
    typed.textContent = COMMAND;
    renderOutput();
  } else {
    const start = () => {
      let i = 0;
      const tick = () => {
        if (i <= COMMAND.length) {
          typed.textContent = COMMAND.slice(0, i);
          i += 1;
          setTimeout(tick, 18 + Math.random() * 26);
        } else {
          if (caret) caret.style.display = 'none';
          setTimeout(renderOutput, 260);
        }
      };
      tick();
    };
    // Only animate once the terminal scrolls into view.
    const io = new IntersectionObserver(
      (entries, obs) => {
        entries.forEach((e) => {
          if (e.isIntersecting) {
            obs.disconnect();
            start();
          }
        });
      },
      { threshold: 0.35 },
    );
    io.observe(typed);
  }
</script>
