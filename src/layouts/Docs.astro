---
import Base from './Base.astro';
import { href, docsNav } from '../lib/site';

interface Props {
  title: string;
  description?: string;
  eyebrow?: string;
  summary?: string;
}
const { title, description, eyebrow = 'Documentation', summary } = Astro.props;
const current = Astro.url.pathname.replace(/\/$/, '') || '/';
const base = (import.meta.env.BASE_URL || '/').replace(/\/$/, '');
function isActive(path: string) {
  return (`${base}${path}`.replace(/\/$/, '') || '/') === current;
}
---

<Base title={`${title} — ubuntu_setup`} description={description}>
  <div class="mx-auto max-w-6xl px-6">
    <div class="grid gap-0 lg:grid-cols-[var(--spacing-rail)_1fr]">
      <!-- rail -->
      <aside class="hidden border-r border-line lg:block">
        <nav class="sticky top-16 py-12 pr-8">
          {
            docsNav.map((group) => (
              <div class="mb-8">
                <p class="eyebrow mb-3">{group.section}</p>
                <ul class="space-y-0.5">
                  {group.items.map((item) => (
                    <li>
                      <a
                        href={href(item.path)}
                        aria-current={isActive(item.path) ? 'page' : undefined}
                        class:list={[
                          'block border-l-2 py-1.5 pl-3 text-[13.5px] transition-colors',
                          isActive(item.path)
                            ? 'border-ubuntu font-medium text-ink'
                            : 'border-transparent text-ink-soft hover:border-line-strong hover:text-ink',
                        ]}
                      >
                        {item.label}
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            ))
          }
        </nav>
      </aside>

      <!-- content -->
      <div class="min-w-0 py-12 lg:py-16 lg:pl-12">
        <header class="border-b border-line pb-8">
          <p class="eyebrow tick">{eyebrow}</p>
          <h1 class="mt-4 text-3xl font-semibold tracking-[-0.02em] sm:text-4xl">
            {title}
          </h1>
          {summary && <p class="mt-4 max-w-xl text-[15px] leading-relaxed text-ink-soft">{summary}</p>}
        </header>

        <article class="prose mt-10 max-w-2xl">
          <slot />
        </article>
      </div>
    </div>
  </div>
</Base>
