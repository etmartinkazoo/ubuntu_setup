---
import Base from '../layouts/Base.astro';
import Terminal from '../components/Terminal.astro';
import CopyCommand from '../components/CopyCommand.astro';
import { href, CLONE_URL } from '../lib/site';

const cloneOneLiner =
  'git clone https://github.com/etmartinkazoo/ubuntu_setup.git && cd ubuntu_setup && ./setup/bootstrap.sh';

// The six commitments — principles, not a feature list. The spine of the project.
const commitments = [
  {
    n: '01',
    title: 'Beautiful',
    body: 'A workspace that\'s a pleasure to look at — considered type, colour, and defaults, light by day and dark by night.',
  },
  {
    n: '02',
    title: 'Keyboard-driven',
    body: 'Your hands stay on the home row. Panes, navigation, and the commands you run a hundred times a day are a keystroke away.',
  },
  {
    n: '03',
    title: 'Private',
    body: 'Your machine works for you, not for anyone measuring you. Telemetry, crash reporting, and phone-home pings are off from the start.',
  },
  {
    n: '04',
    title: 'Hardened',
    body: 'Locked down without getting in your way — inbound denied by default, security patches automatic, the kernel tightened.',
  },
  {
    n: '05',
    title: 'Efficient',
    body: 'Fast tools and real power management, so you get more work per charge and spend less time waiting on your machine.',
  },
  {
    n: '06',
    title: 'Focused',
    body: 'Your attention is the point. The browser and DNS block the noise by default, with a distraction list you control.',
  },
];

const steps = [
  {
    n: '01',
    title: 'Clone',
    body: 'Pull the repo onto a fresh Ubuntu install. No submodules, no package manager to install first.',
  },
  {
    n: '02',
    title: 'Bootstrap',
    body: 'Run one script. It is idempotent — installs tools, hardens the system, and symlinks the dotfiles.',
  },
  {
    n: '03',
    title: 'Own it',
    body: 'Restart your shell. Everything lives in one repo you control. Fork it, edit it, make it the standard on your team.',
  },
];

// Real excerpts from the dotfiles — verbatim, so the page reflects the repo.
const configs = [
  {
    file: '~/.config/ubuntu_setup/aliases.sh',
    why: 'Safety rails, and one command to ship.',
    lines: [
      ["alias rm=", "'rm -I'", "        # confirm deletes"],
      ["alias gs=", "'git status -sb'", ""],
      ["gp() { git add . &&", "", ""],
      ["  git commit -m ", '"$1"', " && git push }"],
    ],
  },
  {
    file: '~/.config/herdr/config.toml',
    why: 'Keyboard-driven. No phone-home.',
    lines: [
      ["prefix = ", '"ctrl+a"', ""],
      ["focus_pane_left = ", '"prefix+h"', "  # vim nav"],
      ["split_vertical = ", '"prefix+v"', ""],
      ["version_check = ", "false", "        # no pings"],
    ],
  },
  {
    file: '~/.gitconfig',
    why: 'Modern git, nothing to configure.',
    lines: [
      ["[pull]  rebase = ", "true", ""],
      ["[push]  autoSetupRemote = ", "true", ""],
      ["[init]  defaultBranch = ", "main", ""],
      ["[fetch] prune = ", "true", ""],
    ],
  },
];

const claims = [
  { stat: '1', label: 'command to a hardened machine' },
  { stat: '0', label: 'calls home, by default' },
  { stat: '26.04', label: 'Ubuntu · kernel 7' },
];
---

<Base>
  <!-- ── Hero ─────────────────────────────────────────────── -->
  <section class="border-b border-line">
    <div class="mx-auto grid max-w-6xl gap-12 px-6 py-16 lg:grid-cols-[1.05fr_1fr] lg:items-center lg:py-24">
      <div>
        <p class="eyebrow tick">Ubuntu 26.04 · built for Framework · runs anywhere</p>
        <h1 class="mt-6 text-4xl font-semibold leading-[1.04] tracking-[-0.02em] sm:text-5xl lg:text-[3.4rem]">
          Your whole machine,<br />in one repository.
        </h1>
        <p class="mt-6 max-w-md text-[15px] leading-relaxed text-ink-soft">
          <span class="font-semibold text-ink">Ubuntu Candor</span> turns a fresh
          Ubuntu install into a workstation that's beautiful, private, hardened,
          and free of distraction — in one command. Clone it, run
          <span class="font-mono text-ubuntu-ink">./setup/bootstrap.sh</span>,
          and be done.
        </p>

        <div class="mt-8 max-w-lg">
          <CopyCommand command={cloneOneLiner} />
        </div>

        <div class="mt-8 flex items-center gap-6">
          <a
            href={href('/docs/installation/')}
            class="border border-ink bg-ink px-5 py-2.5 font-mono text-xs uppercase tracking-wider text-paper transition-colors hover:bg-ubuntu hover:border-ubuntu"
          >
            Read the guide
          </a>
          <a
            href={href('/docs/whats-inside/')}
            class="font-mono text-xs uppercase tracking-wider text-ink-soft underline decoration-line-strong underline-offset-4 transition-colors hover:text-ink"
          >
            What's inside
          </a>
        </div>
      </div>

      <div class="lg:pl-4">
        <Terminal />
      </div>
    </div>

    <!-- claims strip -->
    <div class="border-t border-line">
      <div class="mx-auto grid max-w-6xl grid-cols-3 divide-x divide-line px-6">
        {
          claims.map((c) => (
            <div class="px-2 py-6 first:pl-0 last:pr-0 sm:px-6">
              <div class="font-mono text-2xl font-medium tracking-tight text-ink sm:text-3xl">
                {c.stat}
              </div>
              <div class="mt-1 text-[13px] leading-snug text-ink-faint">{c.label}</div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ── The six commitments ──────────────────────────────── -->
  <section class="border-b border-line">
    <div class="mx-auto max-w-6xl px-6 py-16 lg:py-20">
      <div class="grid gap-10 lg:grid-cols-[0.9fr_1.6fr]">
        <div class="lg:sticky lg:top-24 lg:self-start">
          <p class="eyebrow">What it stands for</p>
          <h2 class="mt-4 text-2xl font-semibold tracking-tight sm:text-3xl">
            Six commitments.
          </h2>
          <p class="mt-4 max-w-xs text-[15px] leading-relaxed text-ink-soft">
            Not a pile of features — a point of view about what a working
            machine should be. Every default traces back to one of these.
          </p>
        </div>

        <ul class="border-t border-line">
          {
            commitments.map((c) => (
              <li class="grid grid-cols-[auto_1fr] gap-x-5 border-b border-line py-6 sm:gap-x-8 sm:py-7">
                <span class="font-mono text-sm text-ubuntu">{c.n}</span>
                <div>
                  <h3 class="text-lg font-semibold tracking-tight">{c.title}</h3>
                  <p class="mt-1.5 max-w-lg text-sm leading-relaxed text-ink-soft">
                    {c.body}
                  </p>
                </div>
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </section>

  <!-- ── The flow ─────────────────────────────────────────── -->
  <section class="border-b border-line">
    <div class="mx-auto max-w-6xl px-6 py-16 lg:py-20">
      <div class="max-w-2xl">
        <p class="eyebrow">The whole process</p>
        <h2 class="mt-4 text-2xl font-semibold tracking-tight sm:text-3xl">
          Three steps. Then it's yours.
        </h2>
      </div>

      <div class="mt-12 grid gap-px border border-line bg-line md:grid-cols-3">
        {
          steps.map((s) => (
            <div class="bg-paper p-8">
              <div class="flex items-baseline gap-3">
                <span class="font-mono text-sm text-ubuntu">{s.n}</span>
                <span class="h-px flex-1 bg-line" />
              </div>
              <h3 class="mt-5 text-lg font-semibold">{s.title}</h3>
              <p class="mt-2.5 text-sm leading-relaxed text-ink-soft">{s.body}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ── The configuration ────────────────────────────────── -->
  <section class="border-b border-line">
    <div class="mx-auto max-w-6xl px-6 py-16 lg:py-20">
      <div class="flex flex-col justify-between gap-4 md:flex-row md:items-end">
        <div class="max-w-2xl">
          <p class="eyebrow">The configuration</p>
          <h2 class="mt-4 text-2xl font-semibold tracking-tight sm:text-3xl">
            Sensible defaults, in plain files.
          </h2>
          <p class="mt-4 max-w-md text-[15px] leading-relaxed text-ink-soft">
            No framework, no DSL. The value isn't a list of packages — it's the
            choices already made for you, each a line you can read and change.
            Straight from the repo:
          </p>
        </div>
        <a
          href={href('/docs/whats-inside/')}
          class="shrink-0 font-mono text-xs uppercase tracking-wider text-ubuntu-ink underline decoration-line-strong underline-offset-4 hover:decoration-ubuntu"
        >
          Every default →
        </a>
      </div>

      <div class="mt-12 grid gap-px border border-line bg-line lg:grid-cols-3">
        {
          configs.map((c) => (
            <div class="flex flex-col bg-ink">
              <div class="border-b border-white/10 px-5 py-3">
                <span class="font-mono text-[11px] text-white/40">{c.file}</span>
              </div>
              <pre class="flex-1 overflow-x-auto px-5 py-4 font-mono text-[12.5px] leading-[1.8] text-[#e9e7e2]">{c.lines.map((l) => (
                <div><span>{l[0]}</span><span class="text-ubuntu">{l[1]}</span><span class="text-white/45">{l[2]}</span></div>
              ))}</pre>
              <div class="border-t border-white/10 px-5 py-3">
                <span class="text-[12.5px] text-white/55">{c.why}</span>
              </div>
            </div>
          ))
        }
      </div>

      <p class="mt-6 text-[13.5px] leading-relaxed text-ink-faint">
        Packages are secondary — a small, curated apt set (ripgrep, fd, jq,
        tree, htop) and nothing you didn't ask for.
        <a href={href('/docs/whats-inside/#packages')} class="text-ubuntu-ink underline decoration-line-strong underline-offset-2 hover:decoration-ubuntu">See the list</a>.
      </p>
    </div>
  </section>

  <!-- ── Framework / hardware ─────────────────────────────── -->
  <section class="border-b border-line">
    <div class="mx-auto grid max-w-6xl gap-12 px-6 py-16 lg:grid-cols-2 lg:items-center lg:py-20">
      <div>
        <p class="eyebrow tick">Framework-first, runs anywhere</p>
        <h2 class="mt-5 text-2xl font-semibold tracking-tight sm:text-3xl">
          Built for Framework. At home on anything.
        </h2>
        <p class="mt-5 max-w-md text-[15px] leading-relaxed text-ink-soft">
          On a Framework 13 or 16 the bootstrap points you at the deepest
          suspend state for real all-day battery. On any other machine that step
          skips — the power tuning, privacy, hardening, and focus setup all
          install the same.
        </p>
        <ul class="prose mt-6 max-w-md">
          <li>powertop auto-tuning on every boot, for more work per charge.</li>
          <li>Deepest suspend state flagged on Framework for lower idle drain.</li>
          <li>Every hardware step guarded by a check — safe on any x86_64 device.</li>
        </ul>
      </div>

      <div class="border border-line bg-panel">
        <div class="border-b border-line px-6 py-4">
          <span class="eyebrow">detected environment</span>
        </div>
        <dl class="divide-y divide-line font-mono text-[13px]">
          {
            [
              ['os', 'Ubuntu 26.04 LTS'],
              ['kernel', '7.x · linux'],
              ['shell', 'bash + herdr'],
              ['runtimes', 'mise'],
              ['firewall', 'ufw · active'],
              ['device', 'Framework · any x86_64'],
            ].map(([k, v]) => (
              <div class="flex items-center justify-between px-6 py-3.5">
                <dt class="text-ink-faint">{k}</dt>
                <dd class="text-ink">{v}</dd>
              </div>
            ))
          }
        </dl>
      </div>
    </div>
  </section>

  <!-- ── Focus / browser ──────────────────────────────────── -->
  <section class="border-b border-line">
    <div class="mx-auto grid max-w-6xl gap-12 px-6 py-16 lg:grid-cols-2 lg:items-center lg:py-20">
      <div>
        <p class="eyebrow tick">For people who ship</p>
        <h2 class="mt-5 text-2xl font-semibold tracking-tight sm:text-3xl">
          Focus is a setting. This turns it on.
        </h2>
        <p class="mt-5 max-w-md text-[15px] leading-relaxed text-ink-soft">
          The browser ships hardened and quiet — telemetry off, no sponsored
          tiles, no onboarding. uBlock Origin is installed and enforced. Every
          DNS lookup leaves the machine encrypted, through a resolver that drops
          known-malicious domains.
        </p>
        <p class="mt-4 max-w-md text-[15px] leading-relaxed text-ink-soft">
          Then there's the blocklist — a plain file of the classic time-sinks.
          Each domain becomes a uBlock rule at install. It's comprehensive
          enough to matter and small enough to read in one sitting: comment out
          what you need, add what you don't, re-run.
        </p>
        <div class="mt-7">
          <a
            href={href('/docs/focus/')}
            class="font-mono text-xs uppercase tracking-wider text-ubuntu-ink underline decoration-line-strong underline-offset-4 hover:decoration-ubuntu"
          >
            How the blocklist works →
          </a>
        </div>
      </div>

      <div class="border border-line bg-panel">
        <div class="flex items-center justify-between border-b border-line px-6 py-4">
          <span class="eyebrow">setup/blocklist.txt</span>
          <span class="font-mono text-[11px] text-ink-faint">11 blocked · 4 off</span>
        </div>
        <ul class="divide-y divide-line font-mono text-[13px]">
          {
            [
              ['facebook.com', true],
              ['instagram.com', true],
              ['x.com', true],
              ['tiktok.com', true],
              ['reddit.com', true],
              ['news.ycombinator.com', false],
              ['youtube.com', false],
            ].map(([domain, blocked]) => (
              <li class="flex items-center gap-3 px-6 py-2.5">
                <span
                  class:list={[
                    'inline-block h-1.5 w-1.5',
                    blocked ? 'bg-ubuntu' : 'bg-transparent ring-1 ring-line-strong',
                  ]}
                />
                <span class:list={[blocked ? 'text-ink' : 'text-ink-faint line-through']}>
                  {domain}
                </span>
                {!blocked && <span class="ml-auto text-[11px] text-ink-faint"># off</span>}
              </li>
            ))
          }
        </ul>
        <div class="border-t border-line px-6 py-3 font-mono text-[11px] text-ink-faint">
          edit the file · ./setup/bootstrap.sh --only firefox
        </div>
      </div>
    </div>
  </section>

  <!-- ── Baseline philosophy ──────────────────────────────── -->
  <section class="border-b border-line">
    <div class="mx-auto max-w-6xl px-6 py-16 lg:py-24">
      <div class="mx-auto max-w-3xl text-center">
        <p class="eyebrow">A baseline, not a cage</p>
        <p class="mt-6 text-2xl font-medium leading-[1.4] tracking-[-0.01em] sm:text-[1.75rem]">
          This isn't a framework to learn or a config to fight. It's a
          <span class="text-ubuntu-ink">starting line</span> — sane, private
          defaults in plain files, laid out so you can read every one and change
          anything.
        </p>
        <p class="mt-6 text-[15px] leading-relaxed text-ink-soft">
          The docs walk through what each piece does and how to make it yours.
          Delete what you don't use. Add what you do. Commit it back to your fork.
        </p>
        <div class="mt-8">
          <a
            href={href('/docs/customizing/')}
            class="inline-block border border-ink px-5 py-2.5 font-mono text-xs uppercase tracking-wider text-ink transition-colors hover:bg-ink hover:text-paper"
          >
            How to customize
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ── CTA ──────────────────────────────────────────────── -->
  <section>
    <div class="mx-auto max-w-6xl px-6 py-16 lg:py-24">
      <div class="border border-ink bg-ink p-8 text-paper sm:p-12">
        <div class="grid gap-8 lg:grid-cols-[1fr_auto] lg:items-end">
          <div>
            <p class="font-mono text-[11px] uppercase tracking-[0.18em] text-white/40">
              Start now
            </p>
            <h2 class="mt-4 text-2xl font-semibold tracking-tight sm:text-3xl">
              Fresh install to first prompt.
            </h2>
            <p class="mt-3 max-w-md text-sm leading-relaxed text-white/60">
              Point it at a clean Ubuntu machine and let it run. Come back to a
              workstation that's private, hardened, and already feels like yours.
            </p>
          </div>
          <div class="flex gap-3">
            <a
              href={CLONE_URL}
              class="border border-white/25 px-5 py-2.5 font-mono text-xs uppercase tracking-wider text-paper transition-colors hover:border-ubuntu hover:bg-ubuntu"
            >
              Get the repo
            </a>
            <a
              href={href('/docs/')}
              class="px-5 py-2.5 font-mono text-xs uppercase tracking-wider text-white/60 underline decoration-white/20 underline-offset-4 transition-colors hover:text-white"
            >
              Docs
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</Base>
