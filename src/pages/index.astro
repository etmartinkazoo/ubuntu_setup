---
import Base from '../layouts/Base.astro';
import Terminal from '../components/Terminal.astro';
import CopyCommand from '../components/CopyCommand.astro';
import { href, CLONE_URL } from '../lib/site';

const cloneOneLiner =
  'git clone https://github.com/etmartinkazoo/ubuntu_setup.git && cd ubuntu_setup && ./setup/bootstrap.sh';

const steps = [
  {
    n: '01',
    title: 'Clone',
    body: 'Pull the repo onto a fresh Ubuntu install. No submodules, no package manager to install first.',
  },
  {
    n: '02',
    title: 'Bootstrap',
    body: 'Run one script. It is idempotent — detects your hardware, installs packages, and symlinks the dotfiles.',
  },
  {
    n: '03',
    title: 'Own it',
    body: 'Restart your shell. Everything lives in one repo you control. Fork it, edit it, make it the standard on your team.',
  },
];

const stack = [
  { k: 'bash', v: 'Aliases, safety rails, and git helpers wired into an interactive shell.' },
  { k: 'tmux', v: 'C-a prefix, vim pane navigation, mouse, and a 50k-line scrollback.' },
  { k: 'mise', v: 'Per-project runtimes for node, ruby, and python — no version managers to babysit.' },
  { k: 'git', v: 'Sensible defaults with the GitHub CLI wired in as the credential helper.' },
  { k: 'apt', v: 'A curated package set: build tools, ripgrep, fd, jq, htop, and friends.' },
  { k: 'gh', v: 'The GitHub CLI, authenticated once and reused everywhere.' },
];

const claims = [
  { stat: '1', label: 'command to a working machine' },
  { stat: '0', label: 'hidden global state' },
  { stat: '~3m', label: 'from clone to prompt' },
];
---

<Base>
  <!-- ── Hero ─────────────────────────────────────────────── -->
  <section class="border-b border-line">
    <div class="mx-auto grid max-w-6xl gap-12 px-6 py-16 lg:grid-cols-[1.05fr_1fr] lg:items-center lg:py-24">
      <div>
        <p class="eyebrow tick">Ubuntu 24.04 · Framework laptops</p>
        <h1 class="mt-6 text-4xl font-semibold leading-[1.04] tracking-[-0.02em] sm:text-5xl lg:text-[3.4rem]">
          Your whole machine,<br />in one repository.
        </h1>
        <p class="mt-6 max-w-md text-[15px] leading-relaxed text-ink-soft">
          <span class="font-mono text-ink">ubuntu_setup</span> is an opinionated
          baseline for technical users who want a clean, reproducible workstation.
          Clone it, run <span class="font-mono text-ubuntu-ink">./setup/bootstrap.sh</span>,
          and be done — no ansible, no chef, no yak-shaving.
        </p>

        <div class="mt-8 max-w-lg">
          <CopyCommand command={cloneOneLiner} />
        </div>

        <div class="mt-8 flex items-center gap-6">
          <a
            href={href('/docs/installation/')}
            class="border border-ink bg-ink px-5 py-2.5 font-mono text-xs uppercase tracking-wider text-paper transition-colors hover:bg-ubuntu hover:border-ubuntu"
          >
            Read the guide
          </a>
          <a
            href={href('/docs/whats-inside/')}
            class="font-mono text-xs uppercase tracking-wider text-ink-soft underline decoration-line-strong underline-offset-4 transition-colors hover:text-ink"
          >
            What's inside
          </a>
        </div>
      </div>

      <div class="lg:pl-4">
        <Terminal />
      </div>
    </div>

    <!-- claims strip -->
    <div class="border-t border-line">
      <div class="mx-auto grid max-w-6xl grid-cols-3 divide-x divide-line px-6">
        {
          claims.map((c) => (
            <div class="px-2 py-6 first:pl-0 last:pr-0 sm:px-6">
              <div class="font-mono text-2xl font-medium tracking-tight text-ink sm:text-3xl">
                {c.stat}
              </div>
              <div class="mt-1 text-[13px] leading-snug text-ink-faint">{c.label}</div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ── The flow ─────────────────────────────────────────── -->
  <section class="border-b border-line">
    <div class="mx-auto max-w-6xl px-6 py-16 lg:py-20">
      <div class="max-w-2xl">
        <p class="eyebrow">The whole process</p>
        <h2 class="mt-4 text-2xl font-semibold tracking-tight sm:text-3xl">
          Three steps. Then it's yours.
        </h2>
      </div>

      <div class="mt-12 grid gap-px border border-line bg-line md:grid-cols-3">
        {
          steps.map((s) => (
            <div class="bg-paper p-8">
              <div class="flex items-baseline gap-3">
                <span class="font-mono text-sm text-ubuntu">{s.n}</span>
                <span class="h-px flex-1 bg-line" />
              </div>
              <h3 class="mt-5 text-lg font-semibold">{s.title}</h3>
              <p class="mt-2.5 text-sm leading-relaxed text-ink-soft">{s.body}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ── Stack ────────────────────────────────────────────── -->
  <section class="border-b border-line">
    <div class="mx-auto max-w-6xl px-6 py-16 lg:py-20">
      <div class="flex flex-col justify-between gap-4 md:flex-row md:items-end">
        <div class="max-w-2xl">
          <p class="eyebrow">The stack</p>
          <h2 class="mt-4 text-2xl font-semibold tracking-tight sm:text-3xl">
            Curated, not exhaustive.
          </h2>
          <p class="mt-4 max-w-md text-[15px] leading-relaxed text-ink-soft">
            Every tool earns its place. These are the defaults a working
            developer reaches for daily — nothing you'll spend a weekend
            ripping back out.
          </p>
        </div>
        <a
          href={href('/docs/whats-inside/')}
          class="shrink-0 font-mono text-xs uppercase tracking-wider text-ubuntu-ink underline decoration-line-strong underline-offset-4 hover:decoration-ubuntu"
        >
          Full inventory →
        </a>
      </div>

      <div class="mt-12 grid gap-px border border-line bg-line sm:grid-cols-2 lg:grid-cols-3">
        {
          stack.map((s) => (
            <div class="group bg-paper p-6 transition-colors hover:bg-panel">
              <div class="flex items-center gap-2">
                <span class="inline-block h-1.5 w-1.5 bg-ubuntu opacity-0 transition-opacity group-hover:opacity-100" />
                <span class="font-mono text-sm font-medium text-ink">{s.k}</span>
              </div>
              <p class="mt-3 text-[13.5px] leading-relaxed text-ink-soft">{s.v}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ── Framework ────────────────────────────────────────── -->
  <section class="border-b border-line">
    <div class="mx-auto grid max-w-6xl gap-12 px-6 py-16 lg:grid-cols-2 lg:items-center lg:py-20">
      <div>
        <p class="eyebrow tick">Hardware-aware</p>
        <h2 class="mt-5 text-2xl font-semibold tracking-tight sm:text-3xl">
          Tuned for Framework, at home anywhere.
        </h2>
        <p class="mt-5 max-w-md text-[15px] leading-relaxed text-ink-soft">
          The bootstrap detects Framework 13 and 16 mainboards and applies the
          small fixes that make Ubuntu feel right: fingerprint reader, suspend
          behaviour, and fractional scaling. On other hardware it simply skips
          those steps — the rest installs the same.
        </p>
        <ul class="prose mt-6 max-w-md">
          <li>Power and suspend tuned for daily-driver battery life.</li>
          <li>HiDPI and fractional scaling set sensibly out of the box.</li>
          <li>Everything guarded behind a hardware check — safe to run anywhere.</li>
        </ul>
      </div>

      <div class="border border-line bg-panel">
        <div class="border-b border-line px-6 py-4">
          <span class="eyebrow">detected environment</span>
        </div>
        <dl class="divide-y divide-line font-mono text-[13px]">
          {
            [
              ['os', 'Ubuntu 24.04 LTS'],
              ['kernel', '6.11 · linux'],
              ['shell', 'bash + tmux'],
              ['runtimes', 'mise'],
              ['device', 'Framework 13 / 16'],
            ].map(([k, v]) => (
              <div class="flex items-center justify-between px-6 py-3.5">
                <dt class="text-ink-faint">{k}</dt>
                <dd class="text-ink">{v}</dd>
              </div>
            ))
          }
        </dl>
      </div>
    </div>
  </section>

  <!-- ── Baseline philosophy ──────────────────────────────── -->
  <section class="border-b border-line">
    <div class="mx-auto max-w-6xl px-6 py-16 lg:py-24">
      <div class="mx-auto max-w-3xl text-center">
        <p class="eyebrow">A baseline, not a cage</p>
        <p class="mt-6 text-2xl font-medium leading-[1.4] tracking-[-0.01em] sm:text-[1.75rem]">
          This isn't a framework to learn or a config to fight. It's a
          <span class="text-ubuntu-ink">starting line</span> — sane defaults in
          plain files, laid out so you can read every one and change anything.
        </p>
        <p class="mt-6 text-[15px] leading-relaxed text-ink-soft">
          The docs walk through what each piece does and how to make it yours.
          Delete what you don't use. Add what you do. Commit it back to your fork.
        </p>
        <div class="mt-8">
          <a
            href={href('/docs/customizing/')}
            class="inline-block border border-ink px-5 py-2.5 font-mono text-xs uppercase tracking-wider text-ink transition-colors hover:bg-ink hover:text-paper"
          >
            How to customize
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ── CTA ──────────────────────────────────────────────── -->
  <section>
    <div class="mx-auto max-w-6xl px-6 py-16 lg:py-24">
      <div class="border border-ink bg-ink p-8 text-paper sm:p-12">
        <div class="grid gap-8 lg:grid-cols-[1fr_auto] lg:items-end">
          <div>
            <p class="font-mono text-[11px] uppercase tracking-[0.18em] text-white/40">
              Start now
            </p>
            <h2 class="mt-4 text-2xl font-semibold tracking-tight sm:text-3xl">
              Fresh install to first prompt.
            </h2>
            <p class="mt-3 max-w-md text-sm leading-relaxed text-white/60">
              Point it at a clean Ubuntu machine and let it run. Come back to a
              workstation that already feels like yours.
            </p>
          </div>
          <div class="flex gap-3">
            <a
              href={CLONE_URL}
              class="border border-white/25 px-5 py-2.5 font-mono text-xs uppercase tracking-wider text-paper transition-colors hover:border-ubuntu hover:bg-ubuntu"
            >
              Get the repo
            </a>
            <a
              href={href('/docs/')}
              class="px-5 py-2.5 font-mono text-xs uppercase tracking-wider text-white/60 underline decoration-white/20 underline-offset-4 transition-colors hover:text-white"
            >
              Docs
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</Base>
