# ~/.gitconfig — managed by ubuntu_setup
# Personal identity lives in ~/.gitconfig.local (untracked), included below.

[include]
    path = ~/.gitconfig.local

[init]
    defaultBranch = main

[pull]
    rebase = true

[push]
    autoSetupRemote = true
    default = current

[fetch]
    prune = true

[diff]
    colorMoved = default

[column]
    ui = auto

[credential "https://github.com"]
    helper =
    helper = !gh auth git-credential

[credential "https://gist.github.com"]
    helper =
    helper = !gh auth git-credential
